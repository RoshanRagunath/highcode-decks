# n8n webhook URL that handles Gamma presentation generation
# This is a server-side secret — never expose it to the browser
N8N_WEBHOOK_URL=

# Shared password users must enter on /login to access /generate
# Server-side secret — never prefix with NEXT_PUBLIC_
ACCESS_PASSWORD=

# Random secret used to sign session cookies (HMAC-SHA256)
# Generate with: openssl rand -base64 32
# Server-side secret — never prefix with NEXT_PUBLIC_
AUTH_SECRET=
